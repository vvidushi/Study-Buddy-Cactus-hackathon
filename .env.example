# Copy to .env and set values locally. Never commit .env.
#
#   cp .env.example .env
#
# Study Buddy’s default stack is on-device Cactus only; these variables are optional
# unless you run Hugging Face downloads or extend the app with cloud APIs.

# Optional — Google Gemini (current codebase does not call Gemini; reserved for extensions)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — Hugging Face (e.g. cactus download, private models)
HF_TOKEN=your_huggingface_token_here
